<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- SLA Form -->
    <record id="helpdesk_sla_view_form" model="ir.ui.view">
        <field name="name">helpdesk.sla.form</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <form string="SLA Policy">
                <sheet>
                    <group>
                        <group string="General">
                            <field name="name"/>
                            <field name="team_id"/>
                            <field name="stage_id"
                                   domain="['|', ('team_ids', '=', False), ('team_ids', 'in', team_id)]"/>
                            <field name="priority"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Time Limit">
                            <field name="time_days"/>
                            <field name="time_hours" widget="float_time"/>
                            <field name="exclude_weekends"/>
                        </group>
                    </group>
                    <group string="Conditions">
                        <field name="category_ids" widget="many2many_tags"/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                    <field name="description" placeholder="SLA policy description..."/>
                </sheet>
            </form>
        </field>
    </record>

    <!-- SLA List -->
    <record id="helpdesk_sla_view_tree" model="ir.ui.view">
        <field name="name">helpdesk.sla.tree</field>
        <field name="model">helpdesk.sla</field>
        <field name="arch" type="xml">
            <list string="SLA Policies">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="team_id"/>
                <field name="stage_id"/>
                <field name="priority"/>
                <field name="time_days"/>
                <field name="time_hours" widget="float_time"/>
                <field name="exclude_weekends"/>
            </list>
        </field>
    </record>

    <!-- SLA Action -->
    <record id="helpdesk_sla_action" model="ir.actions.act_window">
        <field name="name">SLA Policies</field>
        <field name="res_model">helpdesk.sla</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define your first SLA policy!
            </p>
            <p>
                SLA policies set time limits for reaching specific stages.
                When a ticket breaches its SLA, alerts are triggered automatically.
            </p>
        </field>
    </record>

</odoo>
