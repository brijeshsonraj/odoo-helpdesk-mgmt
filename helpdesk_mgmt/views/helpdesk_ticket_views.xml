<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================ -->
    <!--                   TICKET VIEWS                               -->
    <!-- ============================================================ -->

    <!-- Kanban View -->
    <record id="helpdesk_ticket_view_kanban" model="ir.ui.view">
        <field name="name">helpdesk.ticket.kanban</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id" class="o_kanban_small_column"
                    quick_create_view="helpdesk_mgmt.helpdesk_ticket_view_form_quick_create"
                    sample="1">
                <field name="stage_id"/>
                <field name="user_id"/>
                <field name="priority"/>
                <field name="partner_id"/>
                <field name="color"/>
                <field name="kanban_state"/>
                <field name="sla_status"/>
                <field name="sla_deadline"/>
                <field name="activity_ids"/>
                <progressbar field="kanban_state"
                    colors='{"done": "success", "blocked": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between">
                            <field name="priority" widget="priority"/>
                            <field name="kanban_state" widget="state_selection"/>
                        </div>
                        <field name="number" class="fw-bold text-muted small"/>
                        <field name="name" class="fw-bold"/>
                        <div class="d-flex justify-content-between mt-2">
                            <field name="tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span t-if="record.sla_deadline.raw_value" class="small">
                                <i class="fa fa-clock-o"/> <field name="sla_deadline"/>
                            </span>
                            <field name="user_id" widget="many2one_avatar_user"/>
                        </div>
                        <field name="activity_ids" widget="kanban_activity"/>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Quick Create Form -->
    <record id="helpdesk_ticket_view_form_quick_create" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form.quick_create</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="name" placeholder="Ticket subject..."/>
                    <field name="partner_id"/>
                    <field name="priority" widget="priority"/>
                </group>
            </form>
        </field>
    </record>

    <!-- Tree/List View -->
    <record id="helpdesk_ticket_view_tree" model="ir.ui.view">
        <field name="name">helpdesk.ticket.tree</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list string="Tickets" multi_edit="1" sample="1"
                  decoration-danger="sla_status == 'failed'"
                  decoration-warning="priority == '3'"
                  decoration-muted="is_closed">
                <field name="number" readonly="1"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="team_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
                <field name="category_id" optional="show"/>
                <field name="tag_ids" widget="many2many_tags"
                       options="{'color_field': 'color'}" optional="show"/>
                <field name="priority" widget="priority"/>
                <field name="stage_id"/>
                <field name="sla_deadline" optional="show"/>
                <field name="sla_status" optional="show"
                       widget="badge"
                       decoration-success="sla_status == 'reached'"
                       decoration-danger="sla_status == 'failed'"
                       decoration-info="sla_status == 'ongoing'"/>
                <field name="create_date" optional="hide"/>
                <field name="date_closed" optional="hide"/>
                <field name="kanban_state" widget="state_selection" optional="hide"/>
                <field name="is_closed" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="helpdesk_ticket_view_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form string="Ticket">
                <header>
                    <button name="action_assign_to_me" type="object"
                            string="Assign to Me" class="oe_highlight"
                            invisible="user_id == uid"/>
                    <button name="action_close_ticket" type="object"
                            string="Close Ticket" class="oe_highlight"
                            invisible="is_closed"/>
                    <button name="action_reopen_ticket" type="object"
                            string="Reopen Ticket"
                            invisible="not is_closed"/>
                    <field name="stage_id" widget="statusbar"
                           options="{'clickable': '1', 'fold_field': 'fold'}"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_attachments" type="object"
                                class="oe_stat_button" icon="fa-paperclip">
                            <field name="attachment_count" string="Attachments" widget="statinfo"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Closed"
                            bg_color="text-bg-success"
                            invisible="not is_closed"/>
                    <div class="oe_title">
                        <h1 class="d-flex">
                            <field name="priority" widget="priority" class="me-3"/>
                            <field name="number" readonly="1" class="text-muted me-2"/>
                            <field name="name" placeholder="Ticket subject..."/>
                        </h1>
                    </div>
                    <group>
                        <group name="left">
                            <field name="partner_id"/>
                            <field name="partner_email" widget="email"/>
                            <field name="partner_phone" widget="phone"/>
                            <field name="category_id"/>
                            <field name="tag_ids" widget="many2many_tags"
                                   options="{'color_field': 'color'}"/>
                        </group>
                        <group name="right">
                            <field name="team_id"/>
                            <field name="user_id" widget="many2one_avatar_user"/>
                            <field name="date_deadline"/>
                            <field name="kanban_state" widget="state_selection"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the issue..."/>
                        </page>
                        <page string="SLA" name="sla" invisible="not sla_ids">
                            <group>
                                <group>
                                    <field name="sla_deadline"/>
                                    <field name="sla_status" widget="badge"
                                           decoration-success="sla_status == 'reached'"
                                           decoration-danger="sla_status == 'failed'"
                                           decoration-info="sla_status == 'ongoing'"/>
                                    <field name="sla_reached_datetime"/>
                                </group>
                                <group>
                                    <field name="sla_ids" widget="many2many_tags"/>
                                </group>
                            </group>
                        </page>
                        <page string="Time Tracking" name="timesheet">
                            <group>
                                <group>
                                    <field name="timesheet_hours" widget="float_time"/>
                                </group>
                                <group>
                                    <field name="response_hours" widget="float_time" readonly="1"/>
                                    <field name="close_hours" widget="float_time" readonly="1"/>
                                </group>
                            </group>
                        </page>
                        <page string="Additional Info" name="extra_info">
                            <group>
                                <group>
                                    <field name="create_date" readonly="1"/>
                                    <field name="date_first_response" readonly="1"/>
                                    <field name="date_closed" readonly="1"/>
                                </group>
                                <group>
                                    <field name="active"/>
                                    <field name="is_closed" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="helpdesk_ticket_view_search" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <search string="Search Tickets">
                <field name="name" string="Subject"/>
                <field name="number"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="team_id"/>
                <field name="category_id"/>
                <field name="tag_ids"/>
                <separator/>
                <filter string="My Tickets" name="my_tickets"
                        domain="[('user_id', '=', uid)]"/>
                <filter string="Unassigned" name="unassigned"
                        domain="[('user_id', '=', False)]"/>
                <separator/>
                <filter string="Open" name="open"
                        domain="[('is_closed', '=', False)]"/>
                <filter string="Closed" name="closed"
                        domain="[('is_closed', '=', True)]"/>
                <separator/>
                <filter string="Urgent" name="urgent"
                        domain="[('priority', '=', '3')]"/>
                <filter string="High Priority" name="high_priority"
                        domain="[('priority', 'in', ['2', '3'])]"/>
                <separator/>
                <filter string="SLA Failed" name="sla_failed"
                        domain="[('sla_status', '=', 'failed')]"/>
                <filter string="SLA At Risk" name="sla_at_risk"
                        domain="[('sla_status', '=', 'ongoing'), ('sla_deadline', '&lt;=', context_today())]"/>
                <separator/>
                <filter string="Created Today" name="today"
                        domain="[('create_date', '&gt;=', context_today())]"/>
                <filter string="Created This Week" name="this_week"
                        domain="[('create_date', '&gt;=', (context_today() - relativedelta(days=7)))]"/>
                <separator/>
                <filter string="Archived" name="inactive"
                        domain="[('active', '=', False)]"/>
                <group>
                    <filter string="Stage" name="group_stage"
                            context="{'group_by': 'stage_id'}"/>
                    <filter string="Team" name="group_team"
                            context="{'group_by': 'team_id'}"/>
                    <filter string="Assigned To" name="group_user"
                            context="{'group_by': 'user_id'}"/>
                    <filter string="Priority" name="group_priority"
                            context="{'group_by': 'priority'}"/>
                    <filter string="Category" name="group_category"
                            context="{'group_by': 'category_id'}"/>
                    <filter string="SLA Status" name="group_sla"
                            context="{'group_by': 'sla_status'}"/>
                    <filter string="Creation Date" name="group_create_date"
                            context="{'group_by': 'create_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="helpdesk_ticket_view_pivot" model="ir.ui.view">
        <field name="name">helpdesk.ticket.pivot</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <pivot string="Tickets" sample="1">
                <field name="team_id" type="row"/>
                <field name="stage_id" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="helpdesk_ticket_view_graph" model="ir.ui.view">
        <field name="name">helpdesk.ticket.graph</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <graph string="Tickets" sample="1">
                <field name="create_date" interval="week"/>
                <field name="team_id"/>
            </graph>
        </field>
    </record>

    <!-- Calendar View -->
    <record id="helpdesk_ticket_view_calendar" model="ir.ui.view">
        <field name="name">helpdesk.ticket.calendar</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <calendar string="Tickets" date_start="create_date"
                      color="user_id" mode="month"
                      quick_create="0" event_open_popup="1">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id" widget="many2one_avatar_user"/>
            </calendar>
        </field>
    </record>

    <!-- Action -->
    <record id="helpdesk_ticket_action" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form,pivot,graph,calendar,activity</field>
        <field name="search_view_id" ref="helpdesk_ticket_view_search"/>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No tickets found. Let's create one!
            </p>
            <p>
                Track and resolve customer issues efficiently with Helpdesk Management.
            </p>
        </field>
    </record>

    <!-- Action: My Tickets -->
    <record id="helpdesk_ticket_action_my" model="ir.actions.act_window">
        <field name="name">My Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">kanban,list,form,pivot,graph,activity</field>
        <field name="search_view_id" ref="helpdesk_ticket_view_search"/>
        <field name="context">{'search_default_my_tickets': 1, 'search_default_open': 1}</field>
    </record>

</odoo>
