<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Ticket Merge Wizard Form -->
    <record id="helpdesk_ticket_merge_view_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.merge.form</field>
        <field name="model">helpdesk.ticket.merge</field>
        <field name="arch" type="xml">
            <form string="Merge Tickets">
                <group>
                    <field name="ticket_ids" widget="many2many_tags"/>
                    <field name="target_ticket_id"
                           domain="[('id', 'in', ticket_ids)]"/>
                </group>
                <group string="Options">
                    <field name="merge_description"/>
                    <field name="merge_followers"/>
                    <field name="archive_merged"/>
                </group>
                <footer>
                    <button name="action_merge" type="object"
                            string="Merge Tickets" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Merge Action (called from list view) -->
    <record id="helpdesk_ticket_merge_action" model="ir.actions.act_window">
        <field name="name">Merge Tickets</field>
        <field name="res_model">helpdesk.ticket.merge</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="helpdesk_mgmt.model_helpdesk_ticket"/>
        <field name="binding_view_types">list</field>
    </record>

</odoo>
