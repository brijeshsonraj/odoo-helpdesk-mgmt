<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron: Check SLA Status -->
        <record id="ir_cron_helpdesk_check_sla" model="ir.cron">
            <field name="name">Helpdesk: Check SLA Deadlines</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_sla()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Cron: Auto-close inactive tickets -->
        <record id="ir_cron_helpdesk_auto_close" model="ir.cron">
            <field name="name">Helpdesk: Auto-close Inactive Tickets</field>
            <field name="model_id" ref="model_helpdesk_ticket"/>
            <field name="state">code</field>
            <field name="code">model._cron_auto_close_tickets()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
